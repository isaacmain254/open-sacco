DJANGO_SECRET_KEY=django-insecure-k87*u8p&=#9_sf3b#q-h-hj-ds4^7yjl)!eq+e%lu2u)jcdnx$
DEBUG=True
DJANGO_LOGLEVEL=info
DJANGO_ALLOWED_HOSTS=localhost
# Local `python manage.py` commands use SQLite by default. Docker Compose
# overrides this to `postgres` for the backend service.
DATABASE_MODE=sqlite
SQLITE_DATABASE_NAME=db.sqlite3

# Used only when DATABASE_MODE=postgres (including Docker Compose).
DATABASE_ENGINE=postgresql_psycopg2
DATABASE_NAME=open-sacco-db
DATABASE_USERNAME=admin
DATABASE_PASSWORD=password
DATABASE_HOST=db
DATABASE_PORT=5432

# Postgres specific variables for the db service
POSTGRES_DB=open-sacco-db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
